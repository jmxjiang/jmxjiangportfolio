{
  "problems": [
    {
      "title": "1. Double Array Element-Wise",
      "desc": "Given an array <code>arr</code> of integers, double each element of the array in place. Do not return anything.",
      "examples": [
        {
          "input": "[1, 2, 3]", "output": "[2, 4, 6]", "explanation": "[1*2, 2*2, 3*2] = [2, 4, 6]"
        },
        {
          "input": "[-140, -1, 0, 9, 120]", "output": "[-280, -2, 0, 18, 240]", "explanation": "[-140*2, -1*2, 0*2, 9*2, 120*2] = [-280, -2, 0, 18, 240]"
        }
      ]
    }
  ]
}